# These are set automatically by Vercel once you connect a Postgres
# database and add ADMIN_KEY in Settings → Environment Variables.
# You do NOT need to create a real .env file to deploy — this is just
# for reference (or for running `vercel dev` locally against a linked project).

# Auto-injected by Vercel when you connect Postgres/Neon storage:
POSTGRES_URL=

# Set this yourself in Vercel's dashboard — any long random string.
# Used to view submitted RSVPs at /api/rsvp?key=YOUR_ADMIN_KEY
ADMIN_KEY=
